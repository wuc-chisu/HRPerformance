# Production environment (Ubuntu server / Dotploy)
# Use in deployment environment variables dashboard.
# Do NOT commit real values.

DATABASE_URL="postgresql://your_prod_db_user:your_prod_db_password@your_prod_db_host:5432/hrdatabase"

# Gemini API key for AI comments
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_smtp_app_password_here
SMTP_SECURE=false
HR_EMAIL_FROM="Human Resources <your_email@yourdomain.com>"

# Optional safety flag for one-time schema sync fallback
# Set to true only when needed, then remove.
# ALLOW_DB_PUSH_DATA_LOSS=true
