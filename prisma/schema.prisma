// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id                      String         @id @default(cuid())
  employeeId              String         @unique
  name                    String
  email                   String         @default("")
  department              String
  manager                 String         @default("")
  position                String
  joinDate                DateTime
  workAuthorizationStatus String         @default("Other Work Visa")
  overallOverdueTasks     Int            @default(0)
  onboardingChecklistAssigned Boolean    @default(true)
  systemAccessGmail       Boolean        @default(true)
  systemAccessClickup     Boolean        @default(true)
  systemAccessMoodle      Boolean        @default(true)
  systemAccessGoogleDrive Boolean        @default(true)
  onboardingStep2Completed Boolean       @default(true)
  onboardingStep2Forms    Json           @default("[]")
  onboardingStep3Completed Boolean       @default(true)
  onboardingStep4Completed Boolean       @default(true)
  onboardingStep5Completed Boolean       @default(true)
  onboardingStep6AnnualTracking Boolean  @default(false)
  onboardingStep1UpdatedBy String        @default("System")
  onboardingStep1UpdatedAt DateTime?
  onboardingStep1Notes    String?        @db.Text
  onboardingStep2CompletedAt DateTime?
  onboardingStep3CompletedAt DateTime?
  onboardingStep4CompletedAt DateTime?
  onboardingStep5CompletedAt DateTime?
  onboardingStep6StartedAt DateTime?
  onboardingStep6LastReviewAt DateTime?
  weeklyRecords           WeeklyRecord[]
  tasks                   Task[]
  evaluations             Evaluation[]
  monthlyComments         MonthlyPerformanceComment[]
  incidentRecords         IncidentRecord[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskCompletionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
  OVERDUE
}

model Task {
  id               String               @id @default(cuid())
  employeeId       String
  employee         Employee             @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title            String
  description      String?              @db.Text
  priority         TaskPriority         @default(MEDIUM)
  completionStatus TaskCompletionStatus @default(NOT_STARTED)
  isCompleted      Boolean              @default(false)
  dueDate          DateTime?
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([employeeId])
  @@index([employeeId, completionStatus])
  @@index([employeeId, priority])
  @@index([dueDate])
}

model Evaluation {
  id                 String   @id @default(cuid())
  employeeId         String
  employee           Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  periodStart        DateTime
  periodEnd          DateTime
  evaluatorName      String
  evaluationScore    Float
  taskCompletionRate Float    @default(0)
  overdueTaskCount   Int      @default(0)
  strengths          String?  @db.Text
  improvementAreas   String?  @db.Text
  comments           String?  @db.Text
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([employeeId])
  @@index([employeeId, periodStart, periodEnd])
  @@index([evaluationScore])
}

enum IncidentRecordType {
  MISTAKE
  WARNING
}

enum IncidentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum IncidentAppealDecision {
  PENDING
  APPROVED
  DECLINED
}

enum IncidentFinalAction {
  NONE
  HOUR_REDUCTION
  TERMINATION
}

enum IncidentHistoryType {
  NOTE
  APPEAL
  SYSTEM
  MANAGER_COMMENT
}

model IncidentRecord {
  id             String                 @id @default(cuid())
  employeeId     String
  employee       Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name           String
  department     String
  manager        String
  recordType     IncidentRecordType
  occurrenceDate DateTime
  issuedBy       String
  reason         String                 @db.Text
  status         IncidentStatus         @default(PENDING)
  appealDecision IncidentAppealDecision @default(PENDING)
  decisionDate   DateTime?
  reviewedBy     String?
  finalAction    IncidentFinalAction    @default(NONE)
  isAutoGenerated Boolean               @default(false)
  meetingCompleted Boolean              @default(false)
  emailSent Boolean                     @default(false)
  followUpEmailSent Boolean             @default(false)
  improvementPlanReceived Boolean       @default(false)
  histories      IncidentHistory[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([employeeId, status, recordType])
  @@index([occurrenceDate])
}

model IncidentHistory {
  id          String              @id @default(cuid())
  incidentId  String
  incident    IncidentRecord      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  memo        String              @db.Text
  type        IncidentHistoryType
  createdAt   DateTime            @default(now())
  createdBy   String

  @@index([incidentId, createdAt])
}

model WeeklyRecord {
  id                     String   @id @default(cuid())
  employeeId             String
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate              DateTime
  endDate                DateTime
  plannedWorkHours       Float
  actualWorkHours        Float
  assignedTasks          Int
  assignedTasksDetails   Json     @default("[]") // JSON array storing assigned task priority breakdown
  weeklyOverdueTasks     Int
  overdueTasksDetails    Json     @default("[]") // JSON array storing priority breakdown
  allOverdueTasks        Int      @default(0) // Total overdue tasks from all previous weeks
  allOverdueTasksDetails Json     @default("[]") // JSON array storing priority breakdown for all overdue tasks
  managerComment         String?  @db.Text // Optional manager comment for performance evaluation
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([employeeId])
}

model MonthlyPerformanceComment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  comment    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, year, month])
  @@index([employeeId])
}
