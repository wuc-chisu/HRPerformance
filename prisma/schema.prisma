// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id                      String         @id @default(cuid())
  employeeId              String         @unique
  name                    String
  email                   String         @default("")
  department              String
  manager                 String         @default("")
  position                String
  joinDate                DateTime
  workAuthorizationStatus String         @default("Other Work Visa")
  overallOverdueTasks     Int            @default(0)
  weeklyRecords           WeeklyRecord[]
  monthlyComments         MonthlyPerformanceComment[]
  incidentRecords         IncidentRecord[]
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
}

enum IncidentRecordType {
  MISTAKE
  WARNING
}

enum IncidentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum IncidentAppealDecision {
  PENDING
  APPROVED
  DECLINED
}

enum IncidentFinalAction {
  NONE
  HOUR_REDUCTION
  TERMINATION
}

enum IncidentHistoryType {
  NOTE
  APPEAL
  SYSTEM
  MANAGER_COMMENT
}

model IncidentRecord {
  id             String                 @id @default(cuid())
  employeeId     String
  employee       Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  name           String
  department     String
  manager        String
  recordType     IncidentRecordType
  occurrenceDate DateTime
  issuedBy       String
  reason         String                 @db.Text
  status         IncidentStatus         @default(PENDING)
  appealDecision IncidentAppealDecision @default(PENDING)
  decisionDate   DateTime?
  reviewedBy     String?
  finalAction    IncidentFinalAction    @default(NONE)
  isAutoGenerated Boolean               @default(false)
  meetingCompleted Boolean              @default(false)
  followUpEmailSent Boolean             @default(false)
  improvementPlanReceived Boolean       @default(false)
  histories      IncidentHistory[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([employeeId, status, recordType])
  @@index([occurrenceDate])
}

model IncidentHistory {
  id          String              @id @default(cuid())
  incidentId  String
  incident    IncidentRecord      @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  memo        String              @db.Text
  type        IncidentHistoryType
  createdAt   DateTime            @default(now())
  createdBy   String

  @@index([incidentId, createdAt])
}

model WeeklyRecord {
  id                     String   @id @default(cuid())
  employeeId             String
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate              DateTime
  endDate                DateTime
  plannedWorkHours       Float
  actualWorkHours        Float
  assignedTasks          Int
  assignedTasksDetails   Json     @default("[]") // JSON array storing assigned task priority breakdown
  weeklyOverdueTasks     Int
  overdueTasksDetails    Json     @default("[]") // JSON array storing priority breakdown
  allOverdueTasks        Int      @default(0) // Total overdue tasks from all previous weeks
  allOverdueTasksDetails Json     @default("[]") // JSON array storing priority breakdown for all overdue tasks
  managerComment         String?  @db.Text // Optional manager comment for performance evaluation
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([employeeId])
}

model MonthlyPerformanceComment {
  id         String   @id @default(cuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  comment    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, year, month])
  @@index([employeeId])
}
