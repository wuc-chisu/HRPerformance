# Local development environment (Mac/Windows/Linux local DB)
# Copy to .env.local and fill with local credentials.

DATABASE_URL="postgresql://your_local_db_user:your_local_db_password@localhost:5432/hrperformance"

# Gemini API key for AI comments
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_smtp_app_password_here
SMTP_SECURE=false
HR_EMAIL_FROM="Human Resources <your_email@yourdomain.com>"
