{
  "name": "hr-app",
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "prebuild": "prisma generate",
    "dev": "bash scripts/verify-db-setup.sh && next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "start:production": "bash scripts/setup-production-db.sh && next start -p 3001",
    "db:setup": "bash scripts/setup-production-db.sh",
    "lint": "eslint",
    "setup-db": "npx prisma migrate deploy && node prisma/seed-departments.cjs",
    "seed": "node scripts/safe-seed.cjs",
    "force-seed": "node prisma/seed.cjs",
    "backup": "bash scripts/backup-db.sh",
    "restore": "bash scripts/restore-db.sh",
    "export-to-github": "bash scripts/export-to-github.sh",
    "import-from-json": "bash scripts/import-from-json.sh",
    "export:schedule": "node scripts/schedule-exports.cjs",
    "benchmark:employees": "node scripts/benchmark-employee-processing.cjs",
    "cluster:employees": "node scripts/kmeans-employee-clustering.cjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "next": "16.1.6",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.2",
    "pg": "^8.18.0",
    "prisma": "^7.4.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
